[submodule "lib/modulekit"]
	path = lib/modulekit
	url = https://github.com/rhinestonewtf/modulekit
[submodule "lib/openzeppelin-contracts"]
	path = lib/openzeppelin-contracts
	url = https://github.com/OpenZeppelin/openzeppelin-contracts
[submodule "lib/forge-std"]
	path = lib/forge-std
	url = https://github.com/foundry-rs/forge-std
[submodule "lib/LayerZero"]
	path = lib/LayerZero
	url = https://github.com/LayerZero-Labs/LayerZero.git
[submodule "contracts/lib/LayerZero-v2"]
	path = contracts/lib/LayerZero-v2
	url = https://github.com/LayerZero-Labs/LayerZero-v2.git
